{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ESNext"],
    "types": ["node"],
    "outDir": "./out/tsc/node",
    "tsBuildInfoFile": "./out/tsc/node.tsbuildinfo"
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "electron.vite.config.ts",
    "tailwind.config.ts"
  ]
}
